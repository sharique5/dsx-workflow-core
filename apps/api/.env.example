# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dsx_workflow

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRY=7d
OTP_EXPIRY_MINUTES=10

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@dsx-workflow.com

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=azure

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=dsx-workflow-files

# Cloudflare R2 (post-credits — swap to these)
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=dsx-workflow-files

# ─── WhatsApp (TBD) ──────────────────────────────────────────────────────────
WHATSAPP_PROVIDER_URL=
WHATSAPP_API_KEY=
