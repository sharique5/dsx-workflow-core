# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dsx_workflow

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRY=7d
OTP_EXPIRY_MINUTES=10

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@dsx-workflow.com
WEB_APP_URL=http://localhost:5173
PORTAL_APP_URL=http://localhost:5174

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=azure

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=dsx-workflow-files

# Cloudflare R2 (post-credits — swap to these)
# STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=dsx-workflow-files

# ─── SMS / WhatsApp OTP ──────────────────────────────────────────────────────
# Options: msg91 | twofactor | messagebird_whatsapp | (unset = dev console log)
SMS_PROVIDER=messagebird_whatsapp

# MessageBird Conversations API (used when SMS_PROVIDER=messagebird_whatsapp)
# Get these from https://dashboard.messagebird.com/en/settings/developers
MESSAGEBIRD_API_KEY=
MESSAGEBIRD_WHATSAPP_CHANNEL_ID=

# MSG91 (recommended for India SMS — alternative to MessageBird)
# MSG91_AUTH_KEY=
# MSG91_OTP_TEMPLATE_ID=

# 2Factor.in (SMS only, simpler)
# TWOFACTOR_API_KEY=
